# Report language: en (default) or vi / vietnamese for Vietnamese LLM output
TRADINGAGENTS_REPORT_LANGUAGE=

# Analyst tool calling: auto (default) | native | text — use text or auto for models without native tool calling (e.g. deepseek-r1)
# (Applies to Ollama and vLLM tool-calling fallback)
OLLAMA_ANALYST_TOOL_MODE=

# --- Non-interactive CLI (python -m cli.main) ---
# Set to 1 to skip all prompts; values below are required (except optional notes).
TRADINGAGENTS_CLI_FROM_ENV=1
#
# Ticker(s): first symbol is used for the run (comma-separated allowed).
# STOCK_LIST=SPY
TRADINGAGENTS_STOCK_LIST=BTC-USD,SI=F,GC=F,ETH-USD
#
# TRADINGAGENTS_ANALYSIS_DATE=2025-03-25
TRADINGAGENTS_ANALYSIS_DATE=2026-03-25
#
# Comma-separated: market, social, news, fundamentals
TRADINGAGENTS_ANALYSTS=market,social,news,fundamentals
#
# 1, 3, 5 or shallow, medium, deep
TRADINGAGENTS_RESEARCH_DEPTH=shallow
#
# openai | google | anthropic | xai | openrouter | ollama | vllm | llama_cpp | cerebras
TRADINGAGENTS_LLM_PROVIDER=cerebras
#
# Override API base URL (optional; defaults match interactive CLI)
# TRADINGAGENTS_BACKEND_URL=http://127.0.0.1:8080/v1
#
# Model ids for quick / deep agents (required in env mode)
# TRADINGAGENTS_QUICK_THINK_LLM=Qwen3.5-4B.Q8_0.gguf
# TRADINGAGENTS_DEEP_THINK_LLM=Qwen3.5-4B.Q8_0.gguf
#
# Only if TRADINGAGENTS_LLM_PROVIDER=google
# TRADINGAGENTS_GOOGLE_THINKING_LEVEL=high
#
# Only if TRADINGAGENTS_LLM_PROVIDER=openai
# TRADINGAGENTS_OPENAI_REASONING_EFFORT=medium
#
# OpenAI API base URL (optional; used when provider is openai)
# OPENAI_BASE_URL=https://api.openai.com/v1
#
# llama.cpp OpenAI-compatible base (used when provider is llama_cpp and BACKEND_URL unset)
# LLAMA_CPP_BASE_URL=http://127.0.0.1:8080/v1

# LLM Providers (set the one you use)
OPENAI_API_KEY=
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=
XAI_API_KEY=
OPENROUTER_API_KEY=

# Cerebras Inference (OpenAI-compatible API; set TRADINGAGENTS_LLM_PROVIDER=cerebras)
CEREBRAS_API_KEY=
